<mvc-config>

    <!-- Beans configurados por XML en vez de anotaciones, cargados vía
         <import> desde framework-config.xml. -->

    <bean id="appInfo" class="com.example.config.AppInfo">
        <property name="nombre"  value="Nimbus Demo"/>
        <property name="version" value="1.0.0"/>
    </bean>

    <bean id="welcomeBanner" class="com.example.config.WelcomeBanner">
        <property name="appInfo" ref="appInfo"/>
    </bean>

    <!-- Paquete fuera de com.example: solo se detecta si este component-scan,
         declarado DENTRO del import, se procesa realmente. -->
    <component-scan base-package="com.otropaquete"/>

    <!-- Flujo de validaciones custom (Validator + Errors + MessageSource),
         conectado a CursoController vía @InitBinder. -->
    <bean id="messageSource" class="com.nimbusframework.validation.ResourceBundleMessageSource">
        <property name="basename">
            <value>classpath:application/locallization/trust_resource</value>
        </property>
    </bean>

    <bean id="cursoValidator" class="com.example.validation.CursoValidator"/>

    <!--
      DataSource para el demo de JdbcTemplate/NamedParameterJdbcTemplate (com.example.dao).
      H2 en memoria vía DriverManagerDataSource: simple, sin pool, apto para dev/standalone.

      En WAS 8.5 / Tomcat productivo, la alternativa recomendada es usar el pool de
      conexiones que gestiona el propio contenedor, expuesto por JNDI, reemplazando este
      bean por:

        <bean id="dataSource" class="com.nimbusframework.jdbc.datasource.JndiObjectFactoryBean">
            <property name="jndiName" value="java:comp/env/jdbc/miDataSource"/>
        </bean>

      (En Tomcat ese recurso se declara con un <Resource type="javax.sql.DataSource" .../>
      en META-INF/context.xml o conf/context.xml; en WAS 8.5 se crea un JDBC Provider +
      Data Source desde la consola administrativa.) Cambiar de una opción a la otra no
      requiere tocar nada más: JdbcTemplate/NamedParameterJdbcTemplate solo dependen de
      la interfaz javax.sql.DataSource.
    -->
    <bean id="dataSource" class="com.nimbusframework.jdbc.datasource.DriverManagerDataSource">
        <property name="driverClassName" value="${db.driver}"/>
        <property name="url" value="${db.url}"/>
        <property name="username" value="${db.user}"/>
        <property name="password" value="${db.password}"/>
    </bean>

    <bean id="jdbcTemplate" class="com.nimbusframework.jdbc.JdbcTemplate">
        <property name="dataSource" ref="dataSource"/>
    </bean>

    <bean id="namedParameterJdbcTemplate" class="com.nimbusframework.jdbc.namedparam.NamedParameterJdbcTemplate">
        <property name="jdbcOperations" ref="jdbcTemplate"/>
    </bean>

</mvc-config>
